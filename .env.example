# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# JWT signing secret — change before going to production
JWT_SECRET=replace-with-a-random-64-char-string

# ── Redis (optional — server runs without it, no state persistence) ───────────
# REDIS_URL=redis://localhost:6379

# ── PostgreSQL (optional — match history disabled without it) ──────────────────
# DATABASE_URL=postgresql://cabo:cabo@localhost:5432/cabo

# ── Client (Vite env vars must start with VITE_) ──────────────────────────────
# VITE_SERVER_URL=https://cabo-server.fly.dev
